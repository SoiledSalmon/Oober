# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if the lock file is not desired, it can be added here.
#Pipfile.lock

# poetry
#   Similar to Pipenv, poetry.lock can be ignored or not depending on the preference.
#poetry.lock

# pdm
#   Similar to Pipenv and Poetry, pdm.lock is usually tracked in version control
.pdm-plugins/
.pdm-build/

# PEP 582; vertical environments occupied by bin, lib, include, etc.
__pypackages__/

